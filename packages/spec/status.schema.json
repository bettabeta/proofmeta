{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://proofmeta.org/schemas/v1/status-response.json",
  "title": "ProofMeta Status Response",
  "description": "Typical body returned by a Provider Agent's status_endpoint (GET). Aligns with the License Request document; refine in spec docs.",
  "type": "object",
  "required": ["proofmeta_request", "request_id", "status", "status_history"],
  "additionalProperties": false,
  "properties": {
    "proofmeta_request": {
      "type": "string",
      "enum": ["1.0"]
    },
    "request_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["OPEN", "PENDING", "GRANTED", "DENIED", "REVOKED"]
    },
    "status_history": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["status", "timestamp", "actor"],
        "additionalProperties": false,
        "properties": {
          "status": {
            "type": "string",
            "enum": ["OPEN", "PENDING", "GRANTED", "DENIED", "REVOKED"]
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "actor": {
            "type": "string"
          },
          "note": {
            "type": "string"
          },
          "resolver_data": {
            "type": "object"
          }
        }
      }
    }
  }
}
