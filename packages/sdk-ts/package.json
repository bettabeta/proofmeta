{
  "name": "@proofmeta/sdk-ts",
  "version": "0.1.0",
  "description": "ProofMeta reference TypeScript SDK — create, sign, and verify Signed Envelopes (manifests, license requests, status updates). Chain-agnostic. No payment, delivery, or anchor dependencies in core.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "test": "npm run build && node --test test/*.test.mjs",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.4.0",
    "@scure/base": "^1.1.9"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "~5.7.0"
  },
  "keywords": [
    "proofmeta",
    "sdk",
    "licensing",
    "agents",
    "ai",
    "protocol",
    "did",
    "ed25519",
    "jcs",
    "signed-envelope"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bettabeta/proofmeta.git",
    "directory": "packages/sdk-ts"
  },
  "homepage": "https://github.com/bettabeta/proofmeta#readme",
  "bugs": {
    "url": "https://github.com/bettabeta/proofmeta/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
